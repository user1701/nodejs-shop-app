@layout.app({ title: "Shop - Home Page", isAuthenticated, locals })
    @include('partials/header')

    @slot('main')
        <h1>Welcome to the Home Page</h1>
         <p>Here are some of our products:</p>

        <ul>
            @each(product in products)
                <li>{{ product.title }}</li>
            @else
                <li>No products available at the moment.</li>
            @end
        </ul>
    @endslot

@end
