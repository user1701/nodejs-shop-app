{
    "name": "udemy-nodejs",
    "version": "0.0.2",
    "main": "index.js",
    "scripts": {
        "clean": "rimraf dist",
        "build:prod": "rolldown -c",
        "build": "yarn clean && esbuild src/app.ts --bundle --loader:.edge=copy --platform=node --format=esm --outfile=dist/app.js --packages=external ",
        "build:dev": "yarn clean &&tsc --project tsconfig.build.json && tsc-alias -p tsconfig.build.json",
        "start": "node dist/app.js",
        "dev:env": "tsx watch --include ./src/* --env-file=.env src/app.ts",
        "dev": "tsx watch --include ./src/* src/app.ts",
        "test": "tsc --noEmit",
        "lint": "eslint . --fix",
        "format": "prettier --write ."
    },
    "simple-git-hooks": {
        "pre-commit": "yarn pretty-quick --staged"
    },
    "keywords": [],
    "author": "Karaman Ivan",
    "license": "ISC",
    "description": "",
    "type": "module",
    "devDependencies": {
        "@eslint/js": "^9.33.0",
        "@faker-js/faker": "^9.9.0",
        "@tsconfig/node20": "^20.1.6",
        "@types/compression": "^1.8.1",
        "@types/connect-flash": "^0.0.40",
        "@types/cookie-parser": "^1.4.10",
        "@types/csurf": "^1.11.5",
        "@types/express": "^5.0.3",
        "@types/express-session": "^1.18.2",
        "@types/morgan": "^1.9.10",
        "@types/multer": "^2.1.0",
        "@types/node": "^24.2.1",
        "@types/pdfkit": "^0.17.5",
        "esbuild": "^0.28.0",
        "eslint": "^9.33.0",
        "eslint-config-prettier": "^10.1.8",
        "globals": "^16.3.0",
        "jiti": "^2.5.1",
        "morgan": "^1.10.1",
        "prettier": "^3.8.1",
        "prettier-plugin-edgejs": "^1.0.7",
        "pretty-quick": "^4.2.2",
        "rolldown": "^1.0.0-rc.13",
        "rollup-plugin-esbuild": "^6.2.1",
        "simple-git-hooks": "^2.13.1",
        "tslib": "^2.8.1",
        "tsx": "^4.20.4",
        "typescript": "^5.9.2",
        "typescript-eslint": "^8.40.0"
    },
    "dependencies": {
        "@sendgrid/mail": "^8.1.6",
        "bcryptjs": "^3.0.3",
        "body-parser": "^2.2.2",
        "compression": "^1.8.1",
        "connect-flash": "^0.1.1",
        "connect-mongo": "^6.0.0",
        "cookie-parser": "^1.4.7",
        "csurf": "^1.11.0",
        "dotenv": "^17.3.1",
        "edge.js": "^6.3.0",
        "express": "^5.1.0",
        "express-session": "^1.19.0",
        "express-validator": "^7.3.1",
        "helmet": "^8.1.0",
        "mongodb": "^7.1.0",
        "mongoose": "^9.2.4",
        "multer": "^2.1.1",
        "mysql2": "^3.14.4",
        "pdfkit": "^0.18.0",
        "rimraf": "^6.1.3",
        "sequelize": "^6.37.7",
        "tsc-alias": "^1.8.16",
        "uuid": "^11.1.0"
    }
}
